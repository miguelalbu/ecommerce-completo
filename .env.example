# PostgreSQL
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_password_secure
POSTGRES_DB=ecommerce_db

# Backend
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_this_in_production
DATABASE_URL=postgresql://ecommerce_user:ecommerce_password_secure@postgres-db:5432/ecommerce_db

# Frontend
VITE_API_URL=http://localhost:3000/api

# App Ports
BACKEND_PORT=3000
FRONTEND_PORT=3001
DATABASE_PORT=5432
