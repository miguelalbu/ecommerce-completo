// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// MODELOS DA APLICAÇÃO

model Usuario {
  id               String    @id @default(uuid())
  nome             String
  email            String    @unique
  senhaHash        String    @map("senha_hash")
  funcao           String    @default("ADMIN_GLOBAL")
  ativo            Boolean   @default(true)
  criadoEm         DateTime  @default(now()) @map("criado_em")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  logs             Log[]

  @@map("usuarios")
}

model Categoria {
  id            String         @id @default(uuid())
  nome          String         @unique
  slug          String?        @unique
  produtos      Produto[]
  subcategorias Subcategoria[]

  @@map("categorias")
}

model Subcategoria {
  id          String    @id @default(uuid())
  nome        String
  slug        String
  produtos    Produto[]

  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  categoriaId String    @map("categoria_id")

  @@unique([categoriaId, nome])
  @@unique([categoriaId, slug])
  @@map("subcategorias")
}

model Marca {
  id       String    @id @default(uuid())
  nome     String    @unique
  slug     String    @unique
  produtos Produto[]

  @@map("marcas")
}

model Log {
  id          String   @id @default(uuid())
  acao        String
  descricao   String
  entidade    String
  entidadeId  String?  @map("entidade_id")
  criadoEm   DateTime @default(now()) @map("criado_em")

  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId   String   @map("usuario_id")
  usuarioNome String   @map("usuario_nome")

  @@map("logs")
}

model Loja {
  id       String   @id @default(uuid())
  nome     String
  endereco String?
  telefone String?
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")
  pedidos  Pedido[]

  @@map("lojas")
}

model Produto {
  id             String   @id @default(uuid())
  nome           String
  descricao      String?
  preco          Decimal  @db.Decimal(10, 2)
  precoCompra    Decimal? @map("preco_compra") @db.Decimal(10, 2)
  estoque        Int      @default(0)
  ativo          Boolean  @default(true)
  showInCatalog  Boolean  @default(true) @map("show_in_catalog")
  imageUrl       String?  @map("image_url")
  isFeatured     Boolean  @default(false) @map("is_featured")
  criadoEm      DateTime @default(now()) @map("criado_em")
  volume         Int?
  unidade        String?

  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  categoriaId String    @map("categoria_id")

  marca          Marca?        @relation(fields: [marcaId], references: [id])
  marcaId        String?       @map("marca_id")

  subcategoria   Subcategoria? @relation(fields: [subcategoriaId], references: [id])
  subcategoriaId String?       @map("subcategoria_id")

  itens ItemPedido[]

  @@map("produtos")
}

model Cliente {
  id               String     @id @default(uuid())
  nome             String
  sobrenome        String?
  email            String     @unique
  cpf              String?    @unique
  telefone         String?
  dataNascimento   DateTime?  @map("data_nascimento")
  genero           String?
  senhaHash        String     @map("senha_hash")
  criadoEm         DateTime   @default(now()) @map("criado_em")
  resetToken       String?    @map("reset_token")
  resetTokenExpiry DateTime?  @map("reset_token_expiry")
  pedidos          Pedido[]
  enderecos        Endereco[]

  @@map("clientes")
}

model Endereco {
  id          String  @id @default(uuid())
  rua         String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  cep         String
  principal   Boolean @default(false)

  cliente   Cliente @relation(fields: [clienteId], references: [id])
  clienteId String  @map("cliente_id")

  @@map("enderecos")
}

model Cupom {
  id            String    @id @default(uuid())
  codigo        String    @unique
  tipo          String    // "PERCENTUAL" | "VALOR"
  valor         Decimal   @db.Decimal(10, 2)
  minimo        Decimal?  @db.Decimal(10, 2)
  usosMaximos   Int?      @map("usos_maximos")
  usosAtuais    Int       @default(0) @map("usos_atuais")
  ativo         Boolean   @default(true)
  dataExpiracao DateTime? @map("data_expiracao")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  pedidos       Pedido[]

  @@map("cupons")
}

model Pedido {
  id              String   @id @default(uuid())
  valor_total     Decimal  @db.Decimal(10, 2)
  desconto        Decimal? @db.Decimal(10, 2)
  status          String   @default("PENDENTE")
  criadoEm        DateTime @default(now()) @map("criado_em")
  cliente_nome    String?
  cliente_telefone String? @map("cliente_telefone")
  codigoRastreio  String?  @map("codigo_rastreio")
  observacao      String?  @db.Text
  forma_pagamento String?  @map("forma_pagamento")
  cliente        Cliente? @relation(fields: [clienteId], references: [id])
  clienteId      String?  @map("cliente_id")
  loja           Loja?    @relation(fields: [lojaId], references: [id])
  lojaId         String?  @map("loja_id")
  cupom          Cupom?   @relation(fields: [cupomId], references: [id])
  cupomId        String?  @map("cupom_id")

  itens ItemPedido[] // Relação com os itens do pedido

  @@map("pedidos")
}

model ItemPedido {
  id                     String  @id @default(uuid())
  quantidade             Int
  precoNoMomentoDaCompra Decimal @map("preco_no_momento_da_compra") @db.Decimal(10, 2)

  pedido   Pedido @relation(fields: [pedidoId], references: [id])
  pedidoId String @map("pedido_id")

  produto   Produto @relation(fields: [produtoId], references: [id])
  produtoId String  @map("produto_id")

  @@map("itens_pedido")
}

model Gasto {
  id         String   @id @default(uuid())
  descricao  String
  valor      Decimal  @db.Decimal(10, 2)
  categoria  String
  data       DateTime
  observacao String?
  criadoPor  String   @map("criado_por")
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@map("gastos")
}

model Boleto {
  id             String    @id @default(uuid())
  descricao      String
  valor          Decimal   @db.Decimal(10, 2)
  dataVencimento DateTime  @map("data_vencimento")
  codigoBarras   String?   @map("codigo_barras")
  linhaDigitavel String?   @map("linha_digitavel")
  status         String    @default("PENDENTE")
  banco          String?
  observacao     String?
  dataPagamento  DateTime? @map("data_pagamento")
  criadoPor      String    @map("criado_por")
  criadoEm       DateTime  @default(now()) @map("criado_em")

  @@map("boletos")
}
